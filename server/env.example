NODE_ENV=development
PORT=5000

# Supabase PostgreSQL connection string
# Example: postgres://username:password@host:5432/database?sslmode=require
SUPABASE_DB_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# JWT configuration
JWT_SECRET=super_secure_jwt_secret_change_me
JWT_EXPIRES_IN=1d

# CORS configuration
CLIENT_ORIGIN=http://localhost:3000

# Rate limiting (for /api/auth)
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=20

